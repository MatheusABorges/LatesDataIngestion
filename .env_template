# ==========================================
# 🧠 MODELO DE IA (EMBEDDINGS)
# ==========================================
# Nome do modelo no Hugging Face. O padrão abaixo é excelente para PT-BR/EN.
EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-mpnet-base-v2

# Define onde o modelo será salvo localmente para evitar downloads repetidos.
# O script irá baixar automaticamente na primeira execução se a pasta não existir.
MODEL_CACHE_DIR=./modelos_locais

# Dispositivo de inferência:
# Use 'cuda' para NVIDIA GPU (Requer drivers instalados - Muito mais rápido).
# Use 'cpu' para processador padrão (Mais lento, porém compatível universalmente).
DEVICE=cuda

# ==========================================
# 🗄️ BANCO DE DADOS VETORIAL (QDRANT)
# ==========================================
# Endereço do Qdrant. Se rodar via Docker na mesma máquina, use localhost.
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Nome da coleção (tabela) onde os vetores serão salvos.
QDRANT_COLLECTION_NAME=lattes_embeddings

# Estratégia de Ingestão:
# True: Apaga a coleção existente e recria do zero (Full Load).
# False: Tenta adicionar apenas novos (Incremental - requer lógica de ID no código).
FORCE_RECREATE_COLLECTION=True

# ==========================================
# 📂 DIRETÓRIOS DE ENTRADA
# ==========================================
# Caminho relativo ou absoluto onde os arquivos .xml do Lattes estão armazenados.
INPUT_XML_DIRECTORY=./data/xmls_brutos

# ==========================================
# ✂️ PARÂMETROS DE CHUNKING (TEXT SPLITTER)
# ==========================================
# Tamanho máximo de cada pedaço de texto (em caracteres/tokens aproximados).
# Valores menores = busca mais precisa. Valores maiores = mais contexto.
CHUNK_SIZE=1000

# Quantidade de caracteres repetidos entre um pedaço e outro para manter coerência.
CHUNK_OVERLAP=200